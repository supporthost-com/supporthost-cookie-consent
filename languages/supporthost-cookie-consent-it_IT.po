#. Plugin Name of the plugin
msgid "SupportHost cookie consent"
msgstr "SupportHost cookie consent"

#. Description of the plugin
msgid ""
"Plugin implements orestbida/cookieconsent cookie consent solution and stores "
"consents in custom database table masquerading the ips."
msgstr ""
"Questo plugin implementa la soluzione cookie consente orestbida/"
"cookieconsent e registra i consensi degli utenti in una tabella custom del "
"database, anonimizzando gli indirizzi IP."

#. Author of the plugin
msgid "SupportHost OU"
msgstr "SupportHost OU"

#. Author URI of the plugin
msgid "https://supporthost.com/"
msgstr "https://supporthost.com/"

